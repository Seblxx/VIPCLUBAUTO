{
  "name": "vip-club-auto",
  "version": "1.0.0",
  "private": true,
  "description": "Luxury Car Washing Experience - VIP Club Auto",
  "dependencies": {
    "framer-motion": "^10.16.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^4.11.0",
    "react-router-dom": "^7.13.2",
    "react-scripts": "5.0.1"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build && npm run postbuild",
    "postbuild": "echo {\"rewrites\": [{\"source\": \"**\", \"destination\": \"/index.html\"}]} > build\\serve.json",
    "serve": "serve -s build -l 3000",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "postinstall": "node scripts/fix-hmr.js"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
